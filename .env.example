# Node 环境 (development | production)
NODE_ENV=development

# Sample Store MCP
SAMPLE_STORE_BASE_URL=http://localhost:3001
# ⚠️ 警告: 请在生产环境中使用真实的 API Key，不要直接使用示例值
SAMPLE_STORE_API_KEY=your_api_key_CHANGE_THIS

# Knowledge Base MCP
KNOWLEDGE_BASE_PATH=./data/knowledge
HATL_DB_PATH=./data/hatl/db.json

# Report Store
REPORT_OUTPUT_PATH=./data/reports

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:8080
